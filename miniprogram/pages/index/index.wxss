.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f2f5 0%, #e8ecef 100%);
}

/* 管理员操作栏 */
.admin-bar {
  display: flex;
  padding: 16rpx 20rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
  gap: 16rpx;
}

.admin-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  background: #1890ff;
  color: #fff;
  font-size: 28rpx;
  border-radius: 8rpx;
}

.admin-btn.secondary {
  background: #fff;
  color: #1890ff;
  border: 1rpx solid #1890ff;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  padding: 16rpx 20rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.search-input {
  flex: 1;
  height: 64rpx;
  padding: 0 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 4rpx;
  font-size: 28rpx;
}

.search-type {
  width: 180rpx;
  margin-left: 16rpx;
}

.picker-text {
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border: 1rpx solid #ddd;
  border-radius: 4rpx;
  font-size: 26rpx;
  color: #666;
}

/* 筛选行 */
.filter-row {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.date-picker {
  padding: 12rpx 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 4rpx;
  font-size: 28rpx;
  color: #666;
}

.clear-date {
  margin-left: 16rpx;
  color: #1890ff;
  font-size: 26rpx;
}

.filter-label {
  font-size: 28rpx;
  color: #333;
}

.filter-value {
  font-size: 28rpx;
  color: #666;
}

.salesman-picker {
  flex: 1;
}

.picker-value {
  font-size: 28rpx;
  color: #1890ff;
}

/* 状态Tab */
.tabs {
  display: flex;
  background: #fff;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.tab-wrapper {
  flex: 1;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tab {
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
}

.tab.active {
  color: #fff;
  background: #e74c3c;
  padding: 16rpx 32rpx;
  border-radius: 4rpx;
}

.badge {
  position: absolute;
  top: 0;
  right: 20rpx;
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  background: #1890ff;
  color: #fff;
  font-size: 22rpx;
  border-radius: 18rpx;
  padding: 0 8rpx;
  pointer-events: none;
}

.badge.green {
  background: #52c41a;
}

.badge.red {
  background: #f5222d;
}

/* 子Tab */
.sub-tabs {
  display: flex;
  background: #fff;
  padding: 0 20rpx;
  border-bottom: 1rpx solid #eee;
}

.sub-tab {
  padding: 20rpx 30rpx;
  font-size: 26rpx;
  color: #666;
}

.sub-tab.active {
  color: #1890ff;
  border-bottom: 4rpx solid #1890ff;
}

/* 列表 */
.list {
  padding: 20rpx;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid #f0f0f0;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-bottom: none;
}

.order-no {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.draft-tag {
  padding: 6rpx 20rpx;
  background: #ff9800;
  color: #fff;
  font-size: 22rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.card-body {
  padding: 20rpx 28rpx;
}

.card-row {
  display: flex;
  padding: 16rpx 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.card-row:last-of-type {
  border-bottom: none;
}

.card-col {
  flex: 1;
  padding: 8rpx 0;
  display: flex;
  flex-direction: column;
}

.col-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.col-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.col-value.price {
  color: #e74c3c;
  font-weight: 600;
}

.col-value.red {
  color: #f5222d;
}

.col-value.green {
  color: #52c41a;
}

.card-time {
  padding: 16rpx 28rpx;
  font-size: 22rpx;
  color: #999;
  background: #fafafa;
}

.card-actions {
  display: flex;
  justify-content: flex-end;
  padding: 20rpx 28rpx;
  border-top: 1rpx solid #f0f0f0;
  gap: 20rpx;
  background: #fafafa;
}

.btn {
  padding: 14rpx 36rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.btn-default {
  background: #f0f0f0;
  color: #666;
}

.btn-warning {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #fff;
}

.btn-danger {
  background: linear-gradient(135deg, #ff416c 0%, #ff4b2b 100%);
  color: #fff;
}

/* 加载状态 */
.loading, .empty {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}
