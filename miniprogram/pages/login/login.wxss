.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 60rpx 40rpx;
  background: #fff;
}

.header {
  text-align: center;
  padding: 80rpx 0;
}

.title {
  font-size: 48rpx;
  font-weight: 600;
  color: #333;
}

.subtitle {
  font-size: 28rpx;
  color: #888;
  margin-top: 16rpx;
}

.form {
  flex: 1;
}

.form-item {
  margin-bottom: 30rpx;
}

.input {
  height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 30rpx;
}

.btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 8rpx;
  font-size: 32rpx;
  border: none;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: #1890ff;
  color: #fff;
}
