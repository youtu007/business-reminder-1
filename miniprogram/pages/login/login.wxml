<view class="login-page">
  <view class="header">
    <view class="title">业务提醒</view>
    <view class="subtitle">车辆业务管理系统</view>
  </view>

  <view class="form">
    <view class="form-item">
      <input
        class="input"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <button class="btn btn-primary" loading="{{loading}}" disabled="{{loading}}" bindtap="handleLogin">
      登录
    </button>
  </view>
</view>
