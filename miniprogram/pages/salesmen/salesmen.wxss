.page {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  padding: 20rpx;
  background: #fff;
}

.add-btn {
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #1890ff;
  color: #fff;
  font-size: 30rpx;
  border-radius: 8rpx;
}

.list {
  padding: 20rpx;
}

.card {
  background: #fff;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.card-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
}

.info {
  display: flex;
  flex-direction: column;
}

.name {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.phone {
  font-size: 28rpx;
  color: #666;
}

.status {
  padding: 8rpx 20rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
}

.status.active {
  background: #e6f7ff;
  color: #1890ff;
}

.status.inactive {
  background: #fff2f0;
  color: #f5222d;
}

.card-actions {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  color: #1890ff;
  border-right: 1rpx solid #f0f0f0;
}

.btn:last-child {
  border-right: none;
}

.btn.warning {
  color: #fa8c16;
}

.btn.success {
  color: #52c41a;
}

.btn.danger {
  color: #f5222d;
}

.loading, .empty {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 28rpx;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 600rpx;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
}

.modal-title {
  padding: 30rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-field {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-field .label {
  width: 140rpx;
  font-size: 28rpx;
  color: #333;
}

.form-field .input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.modal-actions {
  display: flex;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
}

.modal-btn.cancel {
  color: #666;
  background: #f5f5f5;
}

.modal-btn.confirm {
  color: #fff;
  background: #1890ff;
}
