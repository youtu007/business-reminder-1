.page {
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* 顶部卡片 */
.top-card {
  background: #1890ff;
  border-radius: 8rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  color: #fff;
}

.top-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.customer-name {
  font-size: 40rpx;
  font-weight: 500;
}

.edit-btn {
  padding: 8rpx 24rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 4rpx;
  font-size: 26rpx;
}

.tags {
  display: flex;
  gap: 12rpx;
}

.top-card .tag {
  background: rgba(255,255,255,0.2);
  color: #fff;
}

/* 链接样式 */
.link {
  color: #1890ff;
}

/* 高亮 */
.highlight {
  color: #f5222d;
  font-weight: 500;
}

/* 图片标签 */
.image-tabs {
  white-space: nowrap;
  margin-bottom: 16rpx;
}

.image-tab {
  display: inline-block;
  padding: 12rpx 20rpx;
  margin-right: 12rpx;
  background: #f5f5f5;
  border-radius: 4rpx;
  font-size: 24rpx;
  color: #666;
}

.image-tab.active {
  background: #1890ff;
  color: #fff;
}

/* 图片 */
.images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 4rpx;
  background: #f5f5f5;
}

.no-image {
  width: 100%;
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
}

/* 销售计划/还款计划表格 */
.plan-table {
  font-size: 24rpx;
}

.plan-header {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #eee;
  color: #888;
  font-weight: 500;
}

.plan-row {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  align-items: center;
}

.plan-col {
  flex: 1;
  text-align: center;
}

.plan-col-sm {
  flex: 0.5;
}

.plan-amount {
  color: #333;
  font-weight: 500;
}

.plan-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
}

.plan-status-paid {
  background: #f6ffed;
  color: #52c41a;
}

.plan-status-overdue {
  background: #fff1f0;
  color: #f5222d;
}

.plan-status-pending {
  background: #fff7e6;
  color: #fa8c16;
}

.plan-status-partial {
  background: #fff7e6;
  color: #e6a23c;
}

/* 还款底部面板 */
.pay-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 998;
}
.pay-sheet {
  position: fixed; left: 0; right: 0; bottom: 0;
  background: #fff; z-index: 999;
  border-radius: 24rpx 24rpx 0 0;
  padding: 0 40rpx 60rpx;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}
.pay-sheet-show {
  transform: translateY(0);
}
.pay-sheet-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 30rpx 0; border-bottom: 1rpx solid #eee;
}
.pay-sheet-header text { font-size: 28rpx; color: #999; }
.pay-sheet-title { font-size: 30rpx; font-weight: bold; color: #333; }
.pay-sheet-confirm { color: #409eff !important; font-weight: bold; }
.pay-info {
  font-size: 24rpx; color: #909399; text-align: center; padding: 20rpx 0;
}
.pay-field {
  margin-bottom: 20rpx;
}
.pay-field text {
  font-size: 26rpx; color: #666; display: block; margin-bottom: 8rpx;
}
.pay-field input {
  border: 1rpx solid #dcdfe6; border-radius: 8rpx; padding: 16rpx; font-size: 28rpx;
}

/* 完结按钮 */
.complete-btn {
  width: 100%;
}

/* 加载 */
.loading-page {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 300rpx;
  color: #999;
}
