page {
  background: #f5f5f5;
}

.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 0;
  position: relative;
}

.loading-mask {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  color: #999;
  font-size: 28rpx;
}

.form {
  padding: 20rpx;
  position: relative;
  z-index: 1;
}

.section {
  background: #fff;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  position: relative;
  z-index: 1;
}

.section-title {
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  border-bottom: 1rpx solid #f0f0f0;
  background: #fafafa;
}

.field {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.field:last-child {
  border-bottom: none;
}

.label {
  width: 200rpx;
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
}

.label.required::before {
  content: '*';
  color: #f5222d;
  margin-right: 4rpx;
}

.input {
  flex: 1;
  height: 48rpx;
  font-size: 28rpx;
  color: #333;
  text-align: right;
}

.input::placeholder {
  color: #bbb;
}

.value {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #666;
}

/* OCR识别按钮 */
.ocr-btn {
  padding: 8rpx 20rpx;
  background: #fff;
  border: 2rpx solid #333;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #333;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* Picker 样式 */
.picker-wrapper {
  flex: 1;
}

.picker {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  font-size: 28rpx;
  color: #333;
}

.picker .placeholder {
  color: #bbb;
}

.arrow {
  margin-left: 8rpx;
  color: #999;
  font-size: 32rpx;
  transition: transform 0.2s;
}

.arrow.down {
  transform: rotate(90deg);
}

/* 影像资料 */
.image-field {
  border-bottom: 1rpx solid #f5f5f5;
}

.image-field:last-child {
  border-bottom: none;
}

.image-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
}

.image-label {
  font-size: 28rpx;
  color: #333;
}

.image-right {
  display: flex;
  align-items: center;
}

.image-tag {
  font-size: 24rpx;
  color: #999;
  margin-right: 8rpx;
}

.image-tag.required {
  color: #1890ff;
}

.image-content {
  padding: 0 24rpx 24rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.image-item image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
  background: #f5f5f5;
}

.delete-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 36rpx;
  text-align: center;
  background: #f5222d;
  color: #fff;
  border-radius: 50%;
  font-size: 28rpx;
}

.add-image {
  width: 160rpx;
  height: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
  border: 2rpx dashed #ddd;
  border-radius: 8rpx;
}

.add-icon {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.add-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 提交区域 */
.submit-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: column;
  padding: 16rpx 20rpx calc(20rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
  z-index: 9999;
}

/* 底部提示 */
.footer-tip {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.btn-row {
  display: flex;
  gap: 20rpx;
  background-color: #ffffff;
}

.draft-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #fff;
  color: #1890ff;
  font-size: 32rpx;
  border-radius: 8rpx;
  border: 2rpx solid #1890ff;
  text-align: center;
  padding: 0;
  margin: 0;
}

.draft-btn::after {
  border: none;
}

.submit-btn {
  flex: 2;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #1890ff;
  color: #fff;
  font-size: 32rpx;
  border-radius: 8rpx;
  border: none;
  text-align: center;
  padding: 0;
  margin: 0;
}

.submit-btn::after {
  border: none;
}

.draft-btn[disabled],
.submit-btn[disabled] {
  background-color: #ccc;
  color: #fff;
  border-color: #ccc;
}
